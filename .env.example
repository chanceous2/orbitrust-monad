# --- Deploy (server-side, used by Hardhat) ---
# Private key of the wallet that deploys OrbiTrustRegistry to Monad Testnet.
# Use a throwaway/testnet key. NEVER commit a real private key.
PRIVATE_KEY=

# Monad Testnet RPC used by the deploy script and the relayer.
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# --- Sponsored gas relayer (server-side, v2) ---
# Wallet that submits meta-transactions and PAYS GAS for sellers and buyers.
# In dev it can equal PRIVATE_KEY; in prod use a dedicated, funded relayer key.
# If empty, OrbiTrust falls back to PRIVATE_KEY. NEVER commit a real key.
RELAYER_PRIVATE_KEY=

# Secret used to derive buyers' ephemeral signing keys from magic-link tokens
# and to gate the confirmation links. Use a long random value (e.g. 32 bytes
# hex). NEVER commit a real secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ORDER_TOKEN_SECRET=

# Multitenant MVP stores (JSON files). The data/ folder is gitignored.
TENANT_STORE_PATH=./data/tenants.json
ORDER_STORE_PATH=./data/orders.json

# Global guardrail on sponsored (gas-paying) transactions per rolling day (dev).
SPONSORED_TX_DAILY_LIMIT=100

# Magic-link lifetime for buyer confirmation links, in days.
ORDER_TOKEN_TTL_DAYS=7

# --- Seller auth (Better Auth + Mongo) + custodial wallets ---
# MongoDB for seller sessions and custodial wallet records.
MONGODB_URI=mongodb://localhost:27017/orbitrust

# Better Auth session secret (32 bytes hex). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=

# Public base URL for auth callbacks (dev default: http://localhost:3000).
# On Vercel set this and NEXT_PUBLIC_APP_URL to https://your-app.vercel.app
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Encrypts custodial seller private keys at rest. MUST differ from ORDER_TOKEN_SECRET.
SELLER_WALLET_SECRET=

# --- Frontend (public) ---
# Deployed OrbiTrustRegistry address. The deploy script also writes this to
# lib/contract/deployment.json so the frontend works even if this is empty.
NEXT_PUBLIC_ORBITRUST_CONTRACT_ADDRESS=

# Monad Testnet chain id.
NEXT_PUBLIC_CHAIN_ID=10143

# Optional: override the RPC the browser uses for reads.
NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
